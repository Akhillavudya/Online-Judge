PORT=8000
# Allowed browser origin(s) for CORS. Comma-separate multiple hosts in prod,
# e.g. CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:5173
DATABASE_NAME=compiler.db
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Logging & rate limiting (Phase 9) ---
# Root log level: DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
# Max requests per window (seconds) for the compile/run endpoints, counted per
# user (or per IP when anonymous). Set a limit to 0 to disable that limiter.
RUN_RATE_LIMIT=30
RUN_RATE_WINDOW_S=60
SUBMIT_RATE_LIMIT=20
SUBMIT_RATE_WINDOW_S=60

# --- Secure sandboxed execution (Phase 8) ---
# Run user code inside a locked-down Docker container instead of on the host.
# Leave OFF (0) for local development without Docker. Turn ON (1) on a Linux host
# where Docker is installed and the sandbox image has been built:
#   docker build -t online-judge-sandbox backend/sandbox
USE_DOCKER_SANDBOX=0
SANDBOX_IMAGE=online-judge-sandbox
SANDBOX_MEMORY_MB=256
SANDBOX_CPUS=1.0
SANDBOX_COMPILE_MEMORY_MB=512
SANDBOX_COMPILE_TIMEOUT_S=20
